# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GROK_API_KEY / XAI_API_KEY: Optional API keys for x.ai Grok assistant.
# If configured on the server, the app will use this as default for chat.
# Users can also input their own API key directly in the UI of the Chat tab.
GROK_API_KEY=

# AIONLABS_API_KEY: Highly fast and customizable AI provider (aionlabs.ai)
# Supports keys starting with 'alv2_'. If configured, will prioritize AionLabs API.
AIONLABS_API_KEY=

# CEREBRAS_API_KEY: Extremely fast wafer-scale engine AI inference provider (cloud.cerebras.ai)
# Supports keys starting with 'csk-'. If configured, will prioritize Cerebras API.
CEREBRAS_API_KEY=

# GITHUB_API_KEY: GitHub Personal Access Token (starts with 'github_pat_') for GitHub Models API.
GITHUB_API_KEY=

